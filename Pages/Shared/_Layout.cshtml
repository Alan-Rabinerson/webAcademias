<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academias Menorca</title>
    <link rel="stylesheet" href="~/lib/tailwind/tailwind.css" />
    <link rel="stylesheet" href="~/WebAcademias.styles.css" asp-append-version="true" />
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow p-3">
            <img class="navbar-brand h-20 cursor-pointer" src="~/assets/images/logo.png" alt="Academias Menorca" onclick="window.location.href='/'" />
            <div class="mobile-menu">
                <button class="menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <img src="~/assets/icons/menu-icon.svg" alt="Menu" class="h-6 w-6">
                </button>
                <ul class="flex-col hidden list-none md:flex-row md:flex grow justify-content-end gap-4">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Asociacion">La Asociación</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Materias">Materias</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Empresas">Empresas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Noticias">Noticias</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Asociate">Asóciate</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Contact">Contacto</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
    
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Academias Menorca - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>