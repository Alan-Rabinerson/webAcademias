@page "/@{categoria.Nombre.ToLower().Replace(' ', '-')}"
@using WebAcademias.Data
@model CategoriaModel

@{
    var categoria = Model?.categoria;
    ViewData["Title"] = categoria?.Nombre ?? "Categoría";
}
<div class="text-center">
    <h1 class="text-4xl font-bold mb-4">@categoria?.Nombre</h1>
    <p class="text-lg mb-8">@categoria?.Descripcion</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (Model?.academias != null && Model.academias.Count > 0)
    {
        foreach (var academia in Model.academias)
        {
            <div class="bg-white rounded-lg shadow-md p-4">
                <img src="@academia.LogoRuta" alt="@academia.Nombre" class="w-full h-48 object-cover mb-4 rounded">
                <h2 class="text-xl font-semibold mb-2">@academia.Nombre</h2>
                <p class="text-gray-600 mb-4">@academia.Descripcion</p>
                <a href="/academia/@academia.Id" class="text-blue-500 hover:text-blue-700">Ver más</a>
            </div>
        }
    }
</div>