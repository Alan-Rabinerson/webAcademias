@page "/noticia/{id:long}"
@model WebAcademias.Pages.NoticiaModel
@{
var noticia = Model.noticia!;
ViewData["Title"] = noticia.Titulo;

}
<div class="flex flex-col gap-4 px-4 py-6 md:pt-36 lg:px-30">
    <div class="header-noticia border-b border-[#d0daea] pb-6 mb-7">
        <h1 class="text-[clamp(22px,3vw,30px)] font-bold text-azul-oscuro leading-tight mb-4">@noticia.Titulo</h1>
        <h2 class="text-2xl text-azul-oscuro/70">@noticia.Subtitulo</h2>
        <div class="flex items-center gap-5 flex-wrap mt-4">
            <p class="flex items-center gap-2 text-xs md:text-sm text-gris">
                <img src="../assets/icons/fecha.svg" alt="Icono de fecha" class="w-4 h-4" />

                @noticia.Fecha.ToString("dd/MM/yyyy")
            </p>
            <p class="flex items-center gap-2 text-xs md:text-sm text-gris">
                <img src="../assets/icons/user.svg" alt="Icono de usuario" class="w-4 h-4" />
                Equipo PIMELAB
            </p>
        </div>
    </div>
    <div class="contenido-noticia flex gap-6">
        <div class="texto-noticia text-justify flex flex-col gap-4">
            @Html.Raw(noticia.Cuerpo)
        </div>
        @{ 
            var imgRuta = noticia.ImagenRuta ?? string.Empty;
        }
        <img src="@imgRuta" alt='@(string.IsNullOrWhiteSpace(noticia.ImagenNombre) ? "Imagen de noticia" : noticia.ImagenNombre)' class="shrink-0 w-full md:w-1/3 h-auto rounded-md place-self-start" />
    </div>
</div>
